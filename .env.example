# NEXUS Framework - Environment Configuration Example
# Copy this file to .env and fill in your values

# LLM Provider Configuration
NEXUS_PROVIDER=nvidia
NEXUS_MODEL=moonshotai/kimi-k2.5
NEXUS_API_KEY=your-api-key-here
NEXUS_API_BASE=https://integrate.api.nvidia.com/v1

# Alternative: OpenAI
# NEXUS_PROVIDER=openai
# NEXUS_MODEL=gpt-4
# NEXUS_API_KEY=sk-...
# NEXUS_API_BASE=https://api.openai.com/v1

# Alternative: Ollama (local)
# NEXUS_PROVIDER=ollama
# NEXUS_MODEL=llama2
# NEXUS_API_BASE=http://localhost:11434

# Alternative: Anthropic
# NEXUS_PROVIDER=anthropic
# NEXUS_MODEL=claude-3-opus
# NEXUS_API_KEY=sk-ant-...

# Rate Limiting
NEXUS_MAX_RPM=40

# Budget
NEXUS_MAX_TOKENS=100000
NEXUS_MAX_COST_USD=10.0

# Logging
NEXUS_LOG_LEVEL=INFO
NEXUS_LOG_FORMAT=console

# Redis (for distributed rate limiting)
# REDIS_URL=redis://localhost:6379/0

# Docker Sandbox
# SANDBOX_MEMORY_LIMIT=256m
# SANDBOX_CPU_LIMIT=0.5
# SANDBOX_TIMEOUT=60